# URL of the SafeSips real-time presence server (use https:// in production).
# Used for both the Socket.io connection and the REST API (/api/*).
VITE_SERVER_URL=http://localhost:4000

# Optional: base URL of the REST API if it differs from VITE_SERVER_URL.
# Defaults to VITE_SERVER_URL when unset.
# VITE_API_URL=http://localhost:4000

# Optional anti-bot: Cloudflare Turnstile site key. When set, the register and
# waitlist forms render the Turnstile widget. When empty, no widget is shown.
# VITE_TURNSTILE_SITEKEY=

# Production values live in .env.production (used automatically by `vite build`).
