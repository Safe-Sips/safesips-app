# Production server settings. Copy to .env on the host or load via your platform.
NODE_ENV=production
PORT=4000

# Explicit HTTPS origins only — wildcards are rejected in production.
CORS_ORIGINS=https://safesips.org,https://www.safesips.org,https://app.safesips.org

PRESENCE_TTL_MS=60000
SWEEP_INTERVAL_MS=5000
MIN_UPDATE_INTERVAL_MS=2000
MAX_CONNECTIONS_PER_IP=20
