# Port the server listens on
PORT=4000

# Comma-separated list of allowed client origins (CORS + Socket.io).
# Required in production — wildcards (*) are rejected when NODE_ENV=production.
CORS_ORIGINS=http://localhost:5173

# Max simultaneous WebSocket connections per IP address.
MAX_CONNECTIONS_PER_IP=20

# How long (ms) a presence record stays active without an update before it
# is automatically removed.
PRESENCE_TTL_MS=60000

# How often (ms) the server sweeps for and removes expired presence records.
SWEEP_INTERVAL_MS=5000

# Minimum spacing (ms) between accepted location updates from one socket.
# Updates that arrive faster are rejected (rate limiting).
MIN_UPDATE_INTERVAL_MS=2000

# Set to "production" in deployment so the server expects HTTPS/WSS termination.
# Production template: see .env.production (copy to .env on the host).
NODE_ENV=development

# ─────────────────────────── Accounts & data ───────────────────────────

# SQLite database file. Created on first boot. Keep on a persistent volume in
# production (see deploy/docker-compose.yml) or all accounts/reports are lost.
DATABASE_PATH=./data/safesips.db

# JWT signing secret. REQUIRED in production (server refuses to boot without it).
# Generate one with: openssl rand -hex 32
JWT_SECRET=
# Days a login token stays valid.
JWT_TTL_DAYS=7
# bcrypt cost factor for password/answer hashing.
BCRYPT_ROUNDS=11

# Failed-auth throttle (per email + per IP): N fails per window → 429.
AUTH_MAX_FAILS=6
AUTH_FAIL_WINDOW_MS=900000

# Hours an email-verification link stays valid.
EMAIL_TOKEN_TTL_HOURS=24

# Public URL of the web app — used to build email verification links.
WEB_APP_URL=http://localhost:5173

# Optional anti-bot: Cloudflare Turnstile secret key. When set, registration
# and the waitlist verify the Turnstile token server-side. When empty, only the
# built-in throttle + email verification are used.
TURNSTILE_SECRET=

# How often (ms) the check-in scheduler sweeps for due/overdue check-ins.
CHECKIN_SWEEP_INTERVAL_MS=15000

# Dev/CI only: when "1", exposes GET /api/test-token for smoke tests. Ignored
# in production. Never set this in a real deployment.
ALLOW_TEST_TOKEN=0
