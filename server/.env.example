# Port the server listens on
PORT=4000

# Comma-separated list of allowed client origins (CORS + Socket.io).
# Use "*" only for local development.
CORS_ORIGINS=http://localhost:5173

# How long (ms) a presence record stays active without an update before it
# is automatically removed.
PRESENCE_TTL_MS=60000

# How often (ms) the server sweeps for and removes expired presence records.
SWEEP_INTERVAL_MS=5000

# Minimum spacing (ms) between accepted location updates from one socket.
# Updates that arrive faster are rejected (rate limiting).
MIN_UPDATE_INTERVAL_MS=2000

# Set to "production" in deployment so the server expects HTTPS/WSS termination.
NODE_ENV=development
