# SafeSips web client — static build served by nginx
FROM node:20-alpine AS builder
WORKDIR /app
COPY package.json package-lock.json ./
COPY shared/package.json shared/
COPY web/package.json web/
RUN npm ci --workspace=@safesips/shared --workspace=@safesips/web --include-workspace-root
COPY shared/ shared/
COPY web/ web/
COPY web/.env.production web/.env.production
RUN npm run build -w @safesips/shared && npm run build -w @safesips/web

FROM nginx:1.27-alpine
COPY deploy/nginx-web.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/web/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD wget -qO- http://127.0.0.1/health || exit 1
